{
    "name": "dcms",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev:api": "npm run dev -w apps/api",
        "dev:web": "npm run dev -w apps/web",
        "build": "npm run build -w apps/api && npm run build -w apps/web",
        "test": "npm run test -w apps/api && npm run test -w apps/web",
        "lint": "eslint .",
        "typecheck": "npm run typecheck -w apps/api && npm run typecheck -w apps/web"
    },
    "devDependencies": {
        "eslint": "^9.9.0",
        "eslint-plugin-boundaries": "^7.0.2",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.0.0"
    },
    "dependencies": {
        "vite": "8.1.4",
        "vitest": "4.1.10"
    }
}